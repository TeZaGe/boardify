// prisma/schema.prisma

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
}

// ==========================================
// AUTHENTICATION MODELS (NextAuth.js v5)
// ==========================================

model User {
  id              String           @id @default(cuid())
  name            String?
  email           String           @unique
  emailVerified   DateTime?
  image           String?
  passwordHash    String?
  accounts        Account[]
  sessions        Session[]
  boards          Board[]
  columns         Column[]
  companies       Company[]        // Les entreprises suivies par l'utilisateur
  contacts        Contact[]
  tags            Tag[]
  jobApplications JobApplication[]
  homeAddress     String?
  minSalary       Int?             @default(30)
  maxSalary       Int?             @default(80)
  events          Event[]
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
}

model Account {
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([provider, providerAccountId])
}

model Session {
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model VerificationToken {
  identifier String
  token      String
  expires    DateTime

  @@id([identifier, token])
}

// ==========================================
// JOB CRM MODELS
// ==========================================

model Board {
  id          String   @id @default(cuid())
  name        String
  description String?
  emoji       String?  @default("📋")
  isDefault   Boolean  @default(false)
  order       Int      @default(0)

  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  columns     Column[]

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([userId])
  @@unique([userId, name])
}

model Column {
  id              String           @id @default(cuid())
  name            String
  order           Int
  color           String?
  userId          String
  user            User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  boardId         String?
  board           Board?           @relation(fields: [boardId], references: [id], onDelete: Cascade)
  jobApplications JobApplication[]
  historyFrom     JobApplicationHistory[] @relation("ColFrom")
  historyTo       JobApplicationHistory[] @relation("ColTo")

  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt

  @@index([boardId])
  @@unique([userId, boardId, name])
  @@unique([userId, boardId, order])
}

model Company {
  id              String           @id @default(cuid())
  name            String           // Nom de l'entreprise (ex: "Google", "Vercel")
  website         String?          // Site web (ex: "https://google.com")
  logoUrl         String?          // URL du logo (Clearbit API ou favicon)
  userId          String
  user            User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  jobApplications JobApplication[] // Offres liées
  contacts        Contact[]        // Recruteurs chez cette entreprise

  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt

  @@unique([userId, name]) // Une entreprise unique par nom et par utilisateur
  @@index([userId])
}

model JobApplication {
  id              String    @id @default(cuid())
  title           String    // Intitulé du poste
  location        String?   // Paris, Remote, etc.
  description     String?   // Contenu de l'offre (texte/markdown)
  url             String?   // Lien vers l'annonce
  salary          String?   // "45k - 50k", etc.
  source          String?   // "LinkedIn", "Extension", etc.
  
  // Relation avec l'Entreprise
  companyId       String
  company         Company   @relation(fields: [companyId], references: [id], onDelete: Cascade)

  // Positionnement Kanban
  columnId        String
  column          Column    @relation(fields: [columnId], references: [id], onDelete: Cascade)
  order           Int

  // Propriétaire
  userId          String
  user            User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  // Relations enfants
  contacts        Contact[]
  documents       Document[]
  tags            Tag[]
  notes           Note[]
  events          Event[]
  history         JobApplicationHistory[]

  // Relation pour A/B testing des CVs
  appliedCvId     String?
  appliedCv       Document? @relation("AppliedCv", fields: [appliedCvId], references: [id], onDelete: SetNull)

  deletedAt       DateTime? // Soft delete
  appliedAt       DateTime? // Date d'envoi de la candidature
  
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@index([userId, deletedAt])
  @@index([columnId])
  @@index([companyId])
}

model Contact {
  id              String           @id @default(cuid())
  name            String
  role            String?          // Ex: "Recruteur", "Directeur Technique"
  email           String?
  phone           String?
  
  // Relation avec l'Entreprise
  companyId       String?
  company         Company?         @relation(fields: [companyId], references: [id], onDelete: SetNull)
  
  userId          String
  user            User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  jobApplications JobApplication[]

  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt

  @@index([userId])
  @@index([companyId])
}

model Document {
  id               String         @id @default(cuid())
  name             String
  url              String
  type             String         // "CV", "COVER_LETTER", "OTHER"
  jobApplicationId String
  jobApplication   JobApplication @relation(fields: [jobApplicationId], references: [id], onDelete: Cascade)
  
  // Relation inverse pour l'A/B testing des CVs
  appliedJobs      JobApplication[] @relation("AppliedCv")

  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt

  @@index([jobApplicationId])
}

model Tag {
  id              String           @id @default(cuid())
  name            String
  color           String?
  userId          String
  user            User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  jobApplications JobApplication[]

  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt

  @@unique([userId, name])
}

model Note {
  id               String         @id @default(cuid())
  content          String
  jobApplicationId String
  jobApplication   JobApplication @relation(fields: [jobApplicationId], references: [id], onDelete: Cascade)
  
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt

  @@index([jobApplicationId])
}

model Event {
  id               String         @id @default(cuid())
  title            String
  type             String         @default("TASK")
  date             DateTime
  completed        Boolean        @default(false)
  jobApplicationId String?
  jobApplication   JobApplication? @relation(fields: [jobApplicationId], references: [id], onDelete: Cascade)
  userId           String
  user             User           @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt

  @@index([jobApplicationId])
  @@index([userId])
}

model JobApplicationHistory {
  id               String         @id @default(cuid())
  jobApplicationId String
  jobApplication   JobApplication @relation(fields: [jobApplicationId], references: [id], onDelete: Cascade)
  
  fromColumnId     String?
  fromColumn       Column?        @relation("ColFrom", fields: [fromColumnId], references: [id], onDelete: SetNull)
  
  toColumnId       String
  toColumn         Column         @relation("ColTo", fields: [toColumnId], references: [id], onDelete: Cascade)
  
  changedAt        DateTime       @default(now())

  @@index([jobApplicationId])
}


