{
  "manifest_version": 3,
  "name": "Jobby Clipper",
  "version": "1.0.0",
  "description": "Ajoutez des offres d'emploi depuis Indeed, HelloWork, etc., en un clic sur votre Jobby CRM.",
  "permissions": [
    "storage",
    "activeTab"
  ],
  "host_permissions": [
    "http://localhost:3000/*"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icon.png",
      "48": "icon.png",
      "128": "icon.png"
    }
  },
  "content_scripts": [
    {
      "matches": [
        "*://*.indeed.com/*",
        "*://*.indeed.fr/*",
        "*://*.hellowork.com/*"
      ],
      "js": ["content.js"],
      "run_at": "document_end"
    }
  ]
}
